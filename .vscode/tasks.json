{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build WAR (software-code)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\build-no-maven.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\software-code"
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy WAR to Tomcat (RSP)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Copy-Item -Path \"${workspaceFolder}\\software-code\\build\\java-web-json.war\" -Destination \"C:\\Users\\22001\\.rsp\\redhat-community-server-connector\\runtimes\\installations\\tomcat-11.0.0-M6\\apache-tomcat-11.0.0-M6\\webapps\\java-web-json.war\" -Force"
      ],
      "problemMatcher": []
    },
    {
      "label": "Restart Tomcat (RSP)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "& \"C:\\Users\\22001\\.rsp\\redhat-community-server-connector\\runtimes\\installations\\tomcat-11.0.0-M6\\apache-tomcat-11.0.0-M6\\bin\\shutdown.bat\"; Start-Sleep -Seconds 2; & \"C:\\Users\\22001\\.rsp\\redhat-community-server-connector\\runtimes\\installations\\tomcat-11.0.0-M6\\apache-tomcat-11.0.0-M6\\bin\\startup.bat\""
      ],
      "problemMatcher": []
    },
    {
      "label": "Open App in Browser",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Start-Process \"http://localhost:8080/java-web-json/\""
      ],
      "problemMatcher": []
    },
    {
      "label": "Run Web App (One Click)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build WAR (software-code)",
        "Deploy WAR to Tomcat (RSP)",
        "Restart Tomcat (RSP)",
        "Open App in Browser"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
